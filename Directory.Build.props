<Project>

	<PropertyGroup>
		<Deterministic>true</Deterministic>
		<Authors>Flakroup</Authors>
		<Company>Flakroup</Company>
		<Copyright>Copyright © Flakroup 2023</Copyright>
		<GenerateDocumentationFile>false</GenerateDocumentationFile>
		<AppendTargetFrameworkToOutputPath>false</AppendTargetFrameworkToOutputPath>
		<RepositoryType>git</RepositoryType>
	</PropertyGroup>

	<ItemGroup>
		<None Include="$(MSBuildThisFileDirectory)\.editorconfig" Link=".editorconfig"/>
	</ItemGroup>

	<ItemGroup>
		<PackageReference Include="Microsoft.VisualStudio.Threading.Analyzers" Version="17.4.27">
			<PrivateAssets>all</PrivateAssets>
			<IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
		</PackageReference>
	</ItemGroup>

</Project>